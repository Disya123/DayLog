# Database
POSTGRES_USER=daylog
POSTGRES_PASSWORD=daylog_secret
POSTGRES_DB=daylog
DATABASE_URL=postgresql://daylog:daylog_secret@postgres:5432/daylog?schema=public

# JWT
JWT_SECRET=change_me_in_production_min_32_chars_long_string
JWT_EXPIRES_IN=7d
GUEST_JWT_EXPIRES_IN=30d

# Backend
BACKEND_PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Frontend
VITE_API_URL=http://localhost:3001
FRONTEND_PORT=5173
